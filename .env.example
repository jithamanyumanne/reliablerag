# Provider to use. Supported values: ollama
# Add openai, huggingface, etc. as support is added.
PROVIDER=ollama

# Model names — format depends on the provider
EMBEDDING_MODEL=nomic-embed-text-v2-moe:latest

# GENERATOR_MODEL writes the final RAG answer. Bigger = better answers.
GENERATOR_MODEL=gemma4:12b-it-q4_K_M

# JUDGE_MODEL scores responses in the TRACe eval. Smaller = faster iteration.
# Quality requirement is only "good at following a JSON schema."
JUDGE_MODEL=llama3.1:8b-instruct-q4_K_M

# Absolute path to the ChromaDB persistence directory.
# Use an absolute path to avoid cwd-dependent behavior across environments.
# Local example:  CHROMA_PERSIST_DIR=/path/to/reliablerag/data/chroma_db
# Colab example:  CHROMA_PERSIST_DIR=/content/data/chroma_db
CHROMA_PERSIST_DIR=/absolute/path/to/data/chroma_db

# HuggingFace token for authenticated access (higher rate limits, private datasets).
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here